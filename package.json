{
  "name": "imageview",
  "version": "0.1.0",
  "description": "Standalone client-side image viewer: view any image in the browser, fit or actual size, with on-image QR/barcode detection and (later) OCR and translation. Read-only, byte-in, no framework.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:demo": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "prepare": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "jsqr": "^1.4.0"
  }
}
